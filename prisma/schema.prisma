generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Multi-Enterprise / Tenant ───────────────────────────────────────────────

model Enterprise {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  address     String?
  phone       String?
  email       String?
  website     String?
  currency    String   @default("USD")
  taxId       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     EnterpriseMember[]
  contacts    Contact[]
  leads       Lead[]
  products    Product[]
  categories  Category[]
  warehouses  Warehouse[]
  orders      Order[]
  invoices    Invoice[]
  employees   Employee[]
  departments Department[]
}

// ─── Auth & Users ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships   EnterpriseMember[]
}

model EnterpriseMember {
  id           String     @id @default(cuid())
  role         String     @default("member") // owner, admin, member, viewer
  joinedAt     DateTime   @default(now())

  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  enterpriseId String
  enterprise   Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  @@unique([userId, enterpriseId])
}

// ─── CRM ─────────────────────────────────────────────────────────────────────

model Contact {
  id           String     @id @default(cuid())
  firstName    String
  lastName     String
  email        String?
  phone        String?
  company      String?
  position     String?
  address      String?
  city         String?
  country      String?
  notes        String?
  type         String     @default("customer") // customer, supplier, partner
  status       String     @default("active")   // active, inactive, archived
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  enterpriseId String
  enterprise   Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  leads        Lead[]
  orders       Order[]
  invoices     Invoice[]
}

model Lead {
  id           String     @id @default(cuid())
  title        String
  value        Float      @default(0)
  currency     String     @default("USD")
  stage        String     @default("new") // new, qualified, proposal, negotiation, won, lost
  probability  Int        @default(10)
  source       String?    // website, referral, cold-call, advertisement, social-media
  expectedClose DateTime?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  contactId    String?
  contact      Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  enterpriseId String
  enterprise   Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
}

// ─── Inventory ───────────────────────────────────────────────────────────────

model Category {
  id           String     @id @default(cuid())
  name         String
  description  String?
  color        String     @default("#6366f1")
  createdAt    DateTime   @default(now())

  enterpriseId String
  enterprise   Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  products     Product[]
}

model Product {
  id           String     @id @default(cuid())
  name         String
  sku          String
  description  String?
  price        Float      @default(0)
  cost         Float      @default(0)
  quantity     Int        @default(0)
  minStock     Int        @default(5)
  unit         String     @default("pcs")
  image        String?
  status       String     @default("active") // active, discontinued, out-of-stock
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  categoryId   String?
  category     Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  enterpriseId String
  enterprise   Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  orderItems   OrderItem[]
  invoiceItems InvoiceItem[]
  stockEntries StockEntry[]
}

model Warehouse {
  id           String     @id @default(cuid())
  name         String
  address      String?
  city         String?
  country      String?
  capacity     Int        @default(0)
  usedCapacity Int        @default(0)
  status       String     @default("active")
  createdAt    DateTime   @default(now())

  enterpriseId String
  enterprise   Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  stockEntries StockEntry[]
}

model StockEntry {
  id           String    @id @default(cuid())
  quantity     Int
  type         String    // in, out, adjustment
  reference    String?
  notes        String?
  createdAt    DateTime  @default(now())

  productId    String
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
}

// ─── Sales ───────────────────────────────────────────────────────────────────

model Order {
  id           String     @id @default(cuid())
  orderNumber  String
  status       String     @default("draft") // draft, confirmed, shipped, delivered, cancelled
  subtotal     Float      @default(0)
  tax          Float      @default(0)
  total        Float      @default(0)
  notes        String?
  orderDate    DateTime   @default(now())
  deliveryDate DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  contactId    String?
  contact      Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  enterpriseId String
  enterprise   Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  items        OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Float
  total     Float

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String     @id @default(cuid())
  invoiceNumber String
  status        String     @default("draft") // draft, sent, paid, overdue, cancelled
  subtotal      Float      @default(0)
  tax           Float      @default(0)
  total         Float      @default(0)
  notes         String?
  issueDate     DateTime   @default(now())
  dueDate       DateTime?
  paidDate      DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  contactId     String?
  contact       Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  enterpriseId  String
  enterprise    Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  items         InvoiceItem[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  description String
  quantity    Int
  unitPrice   Float
  total       Float

  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

// ─── HR ──────────────────────────────────────────────────────────────────────

model Department {
  id           String     @id @default(cuid())
  name         String
  description  String?
  headCount    Int        @default(0)
  budget       Float      @default(0)
  createdAt    DateTime   @default(now())

  enterpriseId String
  enterprise   Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  employees    Employee[]
}

model Employee {
  id           String     @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String?
  position     String
  salary       Float      @default(0)
  startDate    DateTime   @default(now())
  endDate      DateTime?
  status       String     @default("active") // active, on-leave, terminated
  avatar       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  enterpriseId String
  enterprise   Enterprise  @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  leaveRequests LeaveRequest[]
}

model LeaveRequest {
  id         String   @id @default(cuid())
  type       String   // vacation, sick, personal, maternity, other
  startDate  DateTime
  endDate    DateTime
  status     String   @default("pending") // pending, approved, rejected
  reason     String?
  createdAt  DateTime @default(now())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}
